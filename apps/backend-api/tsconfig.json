{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",
    "skipLibCheck": true,
    
    // NestJS & Dependency Injection Configuration
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    
    // Build Artifacts & Source Mapping
    "declaration": true,
    "sourceMap": true,
    "incremental": true,
    "removeComments": true,
    
    // Testing Framework (Jest) Compatibility
    "isolatedModules": true,
    "types": [
      "node",
      "jest"
    ],
    
    // Internal Path Mapping
    "paths": {
      "src/*": ["./src/*"]
    },
    
    // Type Checking Laxity Constraints
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    
    // Code Quality Rules
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
