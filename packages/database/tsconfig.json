{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    
    // Explicit compilation boundaries
    "rootDir": "./src",
    "outDir": "./dist",
    
    // Generate type declarations for NestJS consumption
    "declaration": true,
    "declarationMap": true,

    // Monorepo Workspace Project References optimization
    "composite": true,
    "incremental": true,
    "preserveWatchOutput": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma"]
}
