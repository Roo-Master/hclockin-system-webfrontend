{
  "name": "@chronos/database",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "db:seed": "ts-node src/seed.ts",
    "db:generate": "prisma generate --schema=prisma/schema",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema",
    "db:push": "prisma db push --schema=prisma/schema",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .turbo"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node": "^25.9.1",
    "express-rate-limit": "^8.5.2",
    "nodemailer": "^8.0.8",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "zod": "^4.4.3"
  }
}
