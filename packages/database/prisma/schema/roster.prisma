// Location: packages/database/prisma/schema/roster.prisma

model ShiftTemplate {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @db.Uuid
  name               String          @db.VarChar(100) // e.g., "Nurse Main Morning"
  type               ShiftType       @default(MORNING)
  startTime          String          @db.VarChar(5)   // 24hr format string baseline: "06:00"
  endTime            String          @db.VarChar(5)   // 24hr format string baseline: "14:00"
  gracePeriodMinutes Int             @default(15)
  createdAt          DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @db.Timestamptz(6)

  // Relations
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments RosterAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("shift_templates")
}

model RosterAssignment {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  userId          String      @db.Uuid
  departmentId    String?     @db.Uuid // Patched: Added to satisfy bidirectional relation constraint
  shiftTemplateId String      @db.Uuid
  date            DateTime    @db.Date        // Pure calendar date: YYYY-MM-DD
  status          ShiftStatus @default(PRESENT)
  createdAt       DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @db.Timestamptz(6)

  // Relations
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull) // Patched back-relation
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)

  // Constraints: An employee can only have one explicit shift assignment per calendar date
  @@unique([userId, date])
  @@index([tenantId])
  @@index([departmentId])
  @@index([date])
  @@map("roster_assignments")
}