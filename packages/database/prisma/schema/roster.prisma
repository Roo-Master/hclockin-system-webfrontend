// Location: packages/database/prisma/schema/roster.prisma

model ShiftTemplate {
  id                        String    @id @default(uuid()) @db.Uuid
  tenantId                  String    @map("tenant_id") @db.Uuid
  name                      String    @db.VarChar(100) // e.g., "Standard 12-Hour Night Shift"
  type                      String    @db.VarChar(30) // "MORNING" | "AFTERNOON" | "NIGHT" | "FLEXIBLE"
  startTime                 String    @map("start_time") @db.VarChar(5) // HH:mm format
  endTime                   String    @map("end_time") @db.VarChar(5) // HH:mm format
  gracePeriodMinutes        Int       @default(15) @map("grace_period_minutes")
  earlyClockInWindowMinutes Int       @default(30) @map("early_clock_in_window_minutes")
  overtimeThresholdMinutes  Int       @default(0) @map("overtime_threshold_minutes")
  isOvernight               Boolean   @default(false) @map("is_overnight")
  isActive                  Boolean   @default(true) @map("is_active")
  effectiveFrom             DateTime? @map("effective_from") @db.Date
  effectiveTo               DateTime? @map("effective_to") @db.Date
  rules                     Json      @default("{}") @db.JsonB
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  tenant                    Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rosterAssignments         RosterAssignment[]
  rosterAssignmentHistories RosterAssignmentHistory[]
  attendanceSummaries       AttendanceSummary[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("shift_templates")
}

model RosterAssignment {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  /// CRITICAL: The exact department where the shift is performed. Natively supports internal floating staff.
  departmentId    String   @map("department_id") @db.Uuid
  shiftTemplateId String   @map("shift_template_id") @db.Uuid
  date            DateTime @db.Date

  /// Overrides the default user base hourly wage for specific locum or intensive care coverage
  overriddenHourlyRate Decimal? @map("overridden_hourly_rate") @db.Decimal(12, 2)

  status                    String    @default("UNVERIFIED") @db.VarChar(30) // "PRESENT" | "ABSENT" | "OFF" | "UNVERIFIED"
  effectiveFrom             DateTime? @map("effective_from") @db.Date
  effectiveTo               DateTime? @map("effective_to") @db.Date
  assignedByUserId          String?   @map("assigned_by_user_id") @db.Uuid
  supersededAt              DateTime? @map("superseded_at") @db.Timestamptz(6)
  supersededByAssignmentId  String?   @map("superseded_by_assignment_id") @db.Uuid
  unassignedAt              DateTime? @map("unassigned_at") @db.Timestamptz(6)
  unassignedReason          String?   @map("unassigned_reason") @db.VarChar(255)
  startTimeSnapshot         String    @map("start_time_snapshot") @db.VarChar(5)
  endTimeSnapshot           String    @map("end_time_snapshot") @db.VarChar(5)
  gracePeriodSnapshot       Int       @map("grace_period_snapshot")
  overtimeThresholdSnapshot Int       @map("overtime_threshold_snapshot")
  overnightSnapshot         Boolean   @map("overnight_snapshot")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  department        Department                @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  shiftTemplate     ShiftTemplate             @relation(fields: [shiftTemplateId], references: [id], onDelete: Restrict)
  attendanceLogs    AttendanceLog[]
  reconciliationLog ReconciliationLog?
  histories         RosterAssignmentHistory[]

  @@index([tenantId, date])
  @@index([tenantId, userId, date])
  @@index([tenantId, userId, date, status])
  @@index([tenantId, userId, date, supersededAt])
  @@index([departmentId, date]) // Allows department heads to pull clean daily floor rosters instantly
  @@map("roster_assignments")
}

model RosterAssignmentHistory {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  rosterAssignmentId      String   @map("roster_assignment_id") @db.Uuid
  userId                  String   @map("user_id") @db.Uuid
  previousShiftTemplateId String?  @map("previous_shift_template_id") @db.Uuid
  newShiftTemplateId      String?  @map("new_shift_template_id") @db.Uuid
  previousDepartmentId    String?  @map("previous_department_id") @db.Uuid
  newDepartmentId         String?  @map("new_department_id") @db.Uuid
  previousStatus          String?  @map("previous_status") @db.VarChar(30)
  newStatus               String   @map("new_status") @db.VarChar(30)
  effectiveDate           DateTime @map("effective_date") @db.Date
  action                  String   @db.VarChar(30) // "ASSIGNED" | "REASSIGNED" | "UNASSIGNED"
  reason                  String?  @db.VarChar(255)
  actorUserId             String?  @map("actor_user_id") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rosterAssignment RosterAssignment @relation(fields: [rosterAssignmentId], references: [id], onDelete: Restrict)
  user             User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  newShiftTemplate ShiftTemplate?   @relation(fields: [newShiftTemplateId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, effectiveDate])
  @@index([rosterAssignmentId])
  @@map("roster_assignment_histories")
}
