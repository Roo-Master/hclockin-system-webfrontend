// ../../packages/database/prisma/schema/super-admin-additions.prisma

model SuperAdmin {
  id               String             @id @default(uuid()) @db.Uuid
  email            String             @unique @db.VarChar(255)
  passwordHash     String             @map("password_hash") @db.VarChar(255)
  firstName        String             @map("first_name") @db.VarChar(100)
  lastName         String             @map("last_name") @db.VarChar(100)
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  impersonationLogs ImpersonationLog[]

  @@map("super_admins")
}

model ImpersonationLog {
  id             String    @id @default(uuid()) @db.Uuid
  superAdminId   String    @map("super_admin_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  reason         String    @db.VarChar(500)
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt        DateTime? @map("ended_at") @db.Timestamptz(6)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  isActive       Boolean   @default(true) @map("is_active")

  superAdmin     SuperAdmin @relation(fields: [superAdminId], references: [id])
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([superAdminId])
  @@index([tenantId])
  @@map("impersonation_logs")
}

model Plan {
  id               String   @id @default(uuid()) @db.Uuid
  tier             PlanTier @unique
  monthlyPriceKes  Decimal  @default(0) @map("monthly_price_kes") @db.Decimal(12, 2)
  annualPriceKes   Decimal  @default(0) @map("annual_price_kes") @db.Decimal(12, 2)
  maxUsers         Int      @default(10) @map("max_users")
  maxLocations     Int      @default(1) @map("max_locations")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("plans")
}

model TenantFeatureFlag {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  flagName  String  @map("flag_name") @db.VarChar(100)
  enabled   Boolean @default(false)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flagName])
  @@map("tenant_feature_flags")
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}