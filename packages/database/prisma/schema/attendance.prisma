model AttendanceLog {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @map("tenant_id") @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  deviceId           String             @map("device_id") @db.Uuid
  rosterAssignmentId String?            @map("roster_assignment_id") @db.Uuid
  direction          String             @db.VarChar(10)
  timestamp          DateTime           @map("timestamp") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @db.Timestamptz(6)
  summaryId          String?            @db.Uuid
  device             Device             @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  rosterAssignment   RosterAssignment?  @relation(fields: [rosterAssignmentId], references: [id])
  summary            AttendanceSummary? @relation(fields: [summaryId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId, direction, timestamp])
  @@index([tenantId, timestamp])
  @@index([userId])
  @@map("attendance_logs")
}

model AttendanceSummary {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  date             DateTime          @db.Date
  firstIn          DateTime?         @db.Timestamptz(6)
  lastOut          DateTime?         @db.Timestamptz(6)
  totalHours       Float?            @db.Real
  status           AttendanceStatus  @default(ABSENT)
  shiftId          String?           @map("shift_id") @db.Uuid
  shiftName        String?           @db.VarChar(100)
  scheduledStart   DateTime?         @db.Timestamptz(6)
  scheduledEnd     DateTime?         @db.Timestamptz(6)
  scheduledHours   Float?            @db.Real
  lateMinutes      Int               @default(0)
  overtimeHours    Float             @default(0) @db.Real
  processedAt      DateTime          @default(now())
  reprocessedCount Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendanceAudits AttendanceAudit[]
  logs             AttendanceLog[]
  shift            ShiftTemplate?    @relation(fields: [shiftId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([tenantId, date])
  @@index([tenantId, userId, date])
  @@index([status])
  @@map("attendance_summary")
}

model AttendanceAudit {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  userId            String             @db.Uuid
  targetSummaryId   String?            @db.Uuid
  targetLogId       String?            @db.Uuid
  actionType        String             @db.VarChar(50)
  justification     String
  oldValues         Json?
  newValues         Json?
  createdAt         DateTime           @default(now())
  attendanceSummary AttendanceSummary? @relation(fields: [targetSummaryId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([targetSummaryId])
  @@map("attendance_audits")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  ON_LEAVE
  UNROSTERED
  HOLIDAY
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  token        String   @unique
  refreshToken String   @unique  // Add this field
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([expiresAt])
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  tenantId     String
  preferences  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}