// Location: packages/database/prisma/schema/attendance.prisma

model AttendanceLog {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  deviceId           String   @map("device_id") @db.Uuid
  rosterAssignmentId String?  @map("roster_assignment_id") @db.Uuid
  direction          String   @db.VarChar(10)

  timestamp DateTime @map("timestamp") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  /// 🛡️ THE PRODUCTION FIX: Capture the actual incremental sequence counter
  /// off the ZKTeco local flash storage array (corresponds to 'uid' or 'log_id')
  hardwareUid Int?     @map("hardware_uid")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  device           Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  rosterAssignment RosterAssignment? @relation(fields: [rosterAssignmentId], references: [id], onDelete: SetNull)

  // ❌ DELETED:
  // @@unique([tenantId, userId, deviceId, direction, timestamp])

  // 🛡️ ENFORCED: True physical uniqueness bounded by the terminal device execution index
  @@unique([tenantId, deviceId, hardwareUid])

  @@index([tenantId, timestamp])
  @@index([userId])
  @@map("attendance_logs")
}

model AttendanceAudit {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid // Admin executing the override
  targetLogId   String?  @map("target_log_id") @db.Uuid
  actionType    String   @map("action_type") @db.VarChar(50) // "MANUAL_CLOCK" | "OVERRIDE"
  justification String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relationships
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("attendance_audits")
}
