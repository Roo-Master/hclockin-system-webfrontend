// Location: packages/database/prisma/schema/attendance.prisma

model AttendanceLog {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @db.Uuid
  userId         String          @db.Uuid
  deviceId       String          @db.VarChar(100)
  timestamp      DateTime        @db.Timestamptz(6) // Actual machine log entry point
  actionDetected ClockAction     @default(UNKNOWN)
  isDeduplicated Boolean         @default(false)
  processedAt    DateTime        @default(now()) @db.Timestamptz(6)

  // Relations
  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits AttendanceAudit[]

  @@index([userId, timestamp])
  @@index([tenantId])
  @@map("attendance_logs")
}

model AttendanceAudit {
  id              String        @id @default(uuid()) @db.Uuid
  attendanceLogId String        @db.Uuid
  adminUserId     String        @db.Uuid
  originalAction  ClockAction
  correctedAction ClockAction
  reasonForChange String        @db.Text
  changedAt       DateTime      @default(now()) @db.Timestamptz(6)

  // Relations
  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  adminUser     User          @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([attendanceLogId])
  @@map("attendance_audits")
}