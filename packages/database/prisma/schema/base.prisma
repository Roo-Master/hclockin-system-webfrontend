datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  //previewFeatures = ["prismaSchemaFolder"]
  //output          = "../../src/generated/client"
}

enum UserRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  DEPARTMENT_HEAD
  STAFF
  EDGE_GATEWAY
}

enum ClockAction {
  IN
  OUT
  UNKNOWN
}

enum ShiftStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  GHOST_SESSION
}

enum ShiftType {
  MORNING   
  AFTERNOON 
  NIGHT     
  CUSTOM    
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
