// Location: packages/database/prisma/schema/base.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
 
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  output          = "../../../../node_modules/.prisma/client"
}

enum UserRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  HR_MANAGER
  SUPERVISOR
  EMPLOYEE
  DEPARTMENT_HEAD
  STAFF
  EDGE_GATEWAY
}

enum ClockAction {
  IN
  OUT
  UNKNOWN
}

enum ShiftStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  GHOST_SESSION
}

// Append to: packages/database/prisma/schema/base.prisma

enum ShiftType {
  MORNING   // e.g., 06:00 - 14:00
  AFTERNOON // e.g., 14:00 - 22:00
  NIGHT     // e.g., 22:00 - 06:00 (Crosses midnight boundary)
  CUSTOM    // Special ad-hoc on-call or emergency tracking
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERN
  LOCUM
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

enum ShiftScheduleType {
  FIXED
  ROTATING
  ON_CALL
  CUSTOM
}

enum EmployeeShiftStatus {
  ACTIVE
  ENDED
  CANCELLED
}
