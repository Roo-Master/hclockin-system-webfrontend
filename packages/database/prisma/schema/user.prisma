// Location: packages/database/prisma/schema/user.prisma

model User {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  departmentId   String?  @map("department_id") @db.Uuid // Home-base department assignment
  payrollNumber  String   @map("payroll_number") @db.VarChar(50) 
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  email          String   @db.VarChar(255)
  phoneNumber    String?  @map("phone_number") @db.VarChar(30)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  role           String   @default("EMPLOYEE") @db.VarChar(30) // "SUPER_ADMIN" | "HOSPITAL_ADMIN" | "DEPT_HEAD" | "EMPLOYEE"
  hourlyRate     Decimal  @default(0.00) @map("hourly_rate") @db.Decimal(12, 2)
  isActive       Boolean  @default(true) @map("is_active")
  
  /// The local identification PIN mapped inside the physical hardware scanner terminal (e.g., "1002")
  devicePin      String   @map("device_pin") @db.VarChar(50)
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relationships
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department        Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  attendanceLogs    AttendanceLog[]
  attendanceAudits  AttendanceAudit[]
  leaveRequests     LeaveRequest[]
  compiledReports   CompiledReport[]
  payslips          Payslip[]
  rosterAssignments RosterAssignment[]
  notificationLogs  NotificationLog[]

  // Enforces data validation boundaries isolated securely per hospital tenant
  @@unique([tenantId, email])
  @@unique([tenantId, payrollNumber])
  @@unique([tenantId, devicePin]) 
  @@index([tenantId])
  @@index([departmentId])
  @@map("users")
}