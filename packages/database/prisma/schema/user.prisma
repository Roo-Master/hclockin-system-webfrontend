// Location: packages/database/prisma/schema/user.prisma

model User {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  departmentId    String?  @db.Uuid
  email           String   @db.VarChar(255)
  passwordHash    String   @db.VarChar(255)
  firstName       String   @db.VarChar(100)
  lastName        String   @db.VarChar(100)
  role            UserRole @default(STAFF)
  biometricUserId String?  @db.VarChar(50) // Hardware-level sync PIN or ID
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  // Core Existing Relations
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department        Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  rosterAssignments RosterAssignment[]
  attendance        AttendanceLog[]
  auditChanges      AttendanceAudit[]
  employeeProfiles  Employee[]

  // [NEW] Added Multi-Tenant SaaS Extension Relations
  leaveRequests     LeaveRequest[]    @relation("EmployeeLeaves") // Absences belonging to this user
  authorizedLeaves  LeaveRequest[]    @relation("AdminApprovals")  // Leave applications approved by this user (Admin/HR role)
  compiledReports   CompiledReport[]                             // Historical system reports compiled by this user

  // Constraints: System email unique globally; Hardware pin unique within a single hospital
  @@unique([email])
  @@unique([tenantId, biometricUserId])
  @@index([tenantId])
  @@index([biometricUserId])
  @@map("users")
}
