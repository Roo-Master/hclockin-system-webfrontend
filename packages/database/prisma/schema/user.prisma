model User {
  id                        String                    @id @default(uuid()) @db.Uuid
  tenantId                  String?                   @map("tenant_id") @db.Uuid
  departmentId              String?                   @map("department_id") @db.Uuid
  payrollNumber             String                    @map("payroll_number") @db.VarChar(50)
  firstName                 String                    @map("first_name") @db.VarChar(100)
  lastName                  String                    @map("last_name") @db.VarChar(100)
  email                     String                    @db.VarChar(255)
  phoneNumber               String?                   @map("phone_number") @db.VarChar(30)
  passwordHash              String                    @map("password_hash") @db.VarChar(255)
  role                      String                    @default("EMPLOYEE") @db.VarChar(30)
  hourlyRate                Decimal                   @default(0.00) @map("hourly_rate") @db.Decimal(12, 2)
  isActive                  Boolean                   @default(true) @map("is_active")
  employmentType            String                    @default("FULL_TIME") @map("employment_type") @db.VarChar(30)
  employmentStatus          String                    @default("ACTIVE") @map("employment_status") @db.VarChar(30)
  devicePin                 String                    @map("device_pin") @db.VarChar(50)
  emergencyContacts         Json                      @default("[]") @map("emergency_contacts")
  profileMetadata           Json                      @default("{}") @map("profile_metadata")
  failedLoginAttempts       Int                       @default(0) @map("failed_login_attempts")
  lockedUntil               DateTime?                 @map("locked_until") @db.Timestamptz(6)
  mustChangePassword        Boolean                   @default(false) @map("must_change_password")
  lastLoginAt               DateTime?                 @map("last_login_at") @db.Timestamptz(6)
  deletedAt                 DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendanceAudits          AttendanceAudit[]
  attendanceLogs            AttendanceLog[]
  attendanceSummaries       AttendanceSummary[]
  compiledReports           CompiledReport[]
  employeeAuditActions      EmployeeAudit[]           @relation("EmployeeAuditActor")
  employeeAudits            EmployeeAudit[]           @relation("EmployeeAuditEmployee")
  leaveRequests             LeaveRequest[]
  notificationLogs          NotificationLog[]
  notificationPreferences   NotificationPreference[]
  userNotificationSettings  UserNotificationSettings?
  notificationDigests       NotificationDigest[]
  notificationRateLimits    NotificationRateLimit[]
  payslips                  Payslip[]
  rosterAssignmentHistories RosterAssignmentHistory[]
  rosterAssignments         RosterAssignment[]
  sessions                  Session[]
  department                Department?               @relation(fields: [departmentId], references: [id])
  tenant                    Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, payrollNumber])
  @@unique([tenantId, devicePin])
  @@index([tenantId])
  @@index([departmentId])
  @@index([tenantId, employmentStatus])
  @@index([tenantId, deletedAt])
  @@map("users")
}

model Session {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  token         String    @unique
  refreshToken  String    @unique @map("refresh_token")
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  userAgent     String?   @map("user_agent") @db.VarChar(512)
  ipAddress     String?   @map("ip_address") @db.VarChar(64)
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmployeeAudit {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  actorUserId   String   @map("actor_user_id") @db.Uuid
  action        String   @db.VarChar(50)
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor         User     @relation("EmployeeAuditActor", fields: [actorUserId], references: [id])
  employee      User     @relation("EmployeeAuditEmployee", fields: [employeeId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("employee_audits")
}

