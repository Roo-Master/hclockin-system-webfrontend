model Tenant {
  id                        String                     @id @default(uuid()) @db.Uuid
  name                      String                     @db.VarChar(255)
  subdomain                 String                     @unique @db.VarChar(100)
  licenseKey                String                     @map("license_key") @db.VarChar(255)
  slug                      String                     @unique
  isActive                  Boolean                    @default(true) @map("is_active")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendanceAudits          AttendanceAudit[]
  attendanceLogs            AttendanceLog[]
  attendanceSummaries       AttendanceSummary[]
  compiledReports           CompiledReport[]
  departments               Department[]
  devices                   Device[]
  employeeAudits            EmployeeAudit[]
  leaveRequests             LeaveRequest[]
  notificationLogs          NotificationLog[]
  notificationPreferences   NotificationPreference[]
  userNotificationSettings  UserNotificationSettings[]
  notificationDigests       NotificationDigest[]
  notificationTemplates     NotificationTemplate[]
  notificationRateLimits    NotificationRateLimit[]
  payrollPeriods            PayrollPeriod[]
  payslips                  Payslip[]
  reconciliationLogs        ReconciliationLog[]
  rosterAssignmentHistories RosterAssignmentHistory[]
  rosterAssignments         RosterAssignment[]
  shiftTemplates            ShiftTemplate[]
  systemSetting             SystemSetting?
  users                     User[]

  @@index([subdomain])
  @@map("tenants")
}
