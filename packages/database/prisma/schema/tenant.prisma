model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(50)
  subdomain   String   @unique @db.VarChar(50)
  licenseKey  String   @map("license_key") @db.VarChar(100)
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  features    Json     @default("{}")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  users           User[]           @relation("UserTenant")
  departments     Department[]     @relation("DepartmentTenant")
  employees       Employee[]       @relation("EmployeeTenant")
  devices         Device[]         @relation("DeviceTenant")
  leaveRequests   LeaveRequest[]   @relation("LeaveRequestTenant")
  attendance      Attendance[]     @relation("AttendanceTenant")
  payrolls        Payroll[]        @relation("PayrollTenant")
  invoices        Invoice[]        @relation("InvoiceTenant")
  settings        Setting?         @relation("SettingTenant")
  shifts          Shift[]          @relation("ShiftTenant")
  rosters         Roster[]         @relation("RosterTenant")

  @@map("tenants")
}
