// Location: packages/database/prisma/schema/tenant.prisma

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)                  // e.g., "St. Teresa Referral Hospital"
  subdomain  String   @unique @db.VarChar(100)         // Parses traffic from: st-teresa.chronos.hospital
  licenseKey String   @map("license_key") @db.VarChar(255)
  slug      String   @unique
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // System Core Relationships
  departments        Department[]
  users              User[]
  devices            Device[]
  shiftTemplates     ShiftTemplate[]
  rosterAssignments  RosterAssignment[]
  attendanceLogs     AttendanceLog[]
  attendanceAudits   AttendanceAudit[]
  reconciliationLogs ReconciliationLog[]
  systemSetting      SystemSetting?
  leaveRequests      LeaveRequest[]
  compiledReports    CompiledReport[]
  notificationLogs   NotificationLog[]
  payrollPeriods     PayrollPeriod[]
  payslips           Payslip[]

  @@index([subdomain])
  @@map("tenants")
}