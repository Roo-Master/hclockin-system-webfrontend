// Location: packages/database/prisma/schema/tenant.prisma

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  subdomain String   @unique @db.VarChar(100)
  licenseKey String   @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Core Existing Relations
  departments       Department[]
  users             User[]
  shiftTemplates    ShiftTemplate[]
  rosterAssignments RosterAssignment[]
  attendance        AttendanceLog[]

  // [NEW] Added Multi-Tenant SaaS Extension Relations
  systemSetting     SystemSetting?       // 1-to-1 operational rule matrix
  leaveRequests     LeaveRequest[]       // 1-to-many staff absence tracker
  compiledReports   CompiledReport[]     // 1-to-many analytics dashboard cache

  @@index([subdomain])
  @@map("tenants")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(20) // e.g., "ICU", "OPD", "PEDS"
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users             User[]
  rosterAssignments RosterAssignment[] // Structural calendar bounds

  // Constraint: Department codes must be unique inside the same hospital
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}