enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  CASH
  MANUAL
}
model Plan {
  id               String    @id @default(cuid())
  tier             PlanTier  @unique
  monthlyPriceKes  Float     @default(0)
  annualPriceKes   Float     @default(0)
  maxUsers         Int       @default(10)
  maxLocations     Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenants          Tenant[]
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model SubscriptionPlan {
  id          String         @id @default(uuid()) @db.Uuid
  code        String         @unique @db.VarChar(50)
  name        String         @db.VarChar(100)
  description String?        @db.Text
  priceCents  Int
  currency    String         @default("KES") @db.VarChar(3)
  billingCycle BillingCycle
  trialDays   Int            @default(0)
  isActive    Boolean        @default(true) @map("is_active")
  features    Json?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  @@index([code])
  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  createdById          String?            @map("created_by_id") @db.Uuid
  updatedById          String?            @map("updated_by_id") @db.Uuid
  status               SubscriptionStatus  @default(TRIALING)
  billingCycle         BillingCycle
  currency             String             @default("KES") @db.VarChar(3)
  amountCents          Int
  trialEndsAt          DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(6)
  renewalAt            DateTime?          @map("renewal_at") @db.Timestamptz(6)
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz(6)
  suspendedAt          DateTime?          @map("suspended_at") @db.Timestamptz(6)
  gatewayCustomerId    String?            @unique @map("gateway_customer_id") @db.VarChar(255)
  gatewaySubscriptionId String?           @unique @map("gateway_subscription_id") @db.VarChar(255)
  autoRenew            Boolean            @default(true) @map("auto_renew")
  metadata             Json?
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan    @relation(fields: [planId], references: [id])
  createdBy            User?              @relation("SubscriptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?              @relation("SubscriptionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  invoices             Invoice[]

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id                  String        @id @default(uuid()) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  subscriptionId      String        @map("subscription_id") @db.Uuid
  createdById         String?       @map("created_by_id") @db.Uuid
  invoiceNumber       String        @unique @map("invoice_number") @db.VarChar(50)
  status              InvoiceStatus @default(OPEN)
  currency            String        @default("KES") @db.VarChar(3)
  subtotalCents       Int           @map("subtotal_cents")
  discountCents       Int           @default(0) @map("discount_cents")
  taxCents            Int           @default(0) @map("tax_cents")
  totalCents          Int           @map("total_cents")
  dueDate             DateTime?     @map("due_date") @db.Timestamptz(6)
  paidAt              DateTime?     @map("paid_at") @db.Timestamptz(6)
  billingPeriodStart  DateTime?     @map("billing_period_start") @db.Timestamptz(6)
  billingPeriodEnd    DateTime?     @map("billing_period_end") @db.Timestamptz(6)
  notes               String?       @db.Text
  gatewayInvoiceId    String?       @unique @map("gateway_invoice_id") @db.VarChar(255)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription        Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdBy           User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lineItems           InvoiceLineItem[]
  payments            Payment[]

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  description     String   @db.VarChar(255)
  quantity        Int      @default(1)
  unitPriceCents  Int      @map("unit_price_cents")
  amountCents     Int      @map("amount_cents")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  invoiceId          String        @map("invoice_id") @db.Uuid
  receivedById       String?       @map("received_by_id") @db.Uuid
  status             PaymentStatus @default(PENDING)
  method             PaymentMethod @default(MANUAL)
  amountCents        Int           @map("amount_cents")
  currency           String        @default("KES") @db.VarChar(3)
  gatewayPaymentId   String?       @unique @map("gateway_payment_id") @db.VarChar(255)
  failureReason      String?       @map("failure_reason") @db.Text
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice            Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receivedBy         User?         @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  reconciliation     Reconciliation?

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model BillingEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  type        String   @db.VarChar(100)
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@map("billing_events")
}